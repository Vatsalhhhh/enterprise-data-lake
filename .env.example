# Copy this file to .env and fill in real values as needed.
# The project runs fully without an OpenAI key -- /analyze falls back to a
# deterministic template engine when OPENAI_API_KEY is unset.

# --- LLM (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- MinIO (S3-compatible object store) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=data-lake

# --- Postgres warehouse ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5544
POSTGRES_DB=warehouse
POSTGRES_USER=warehouse
POSTGRES_PASSWORD=warehouse

# --- Catalog ---
CATALOG_DB_PATH=catalog/catalog.duckdb

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
